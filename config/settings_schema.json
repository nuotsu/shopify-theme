[
  {
    "name": "theme_info",
    "theme_name": "Nuotsu",
    "theme_version": "0.0.1",
    "theme_author": "nuotsu",
    "theme_documentation_url": "https://help.shopify.com/manual/online-store/themes",
    "theme_support_url": "https://support.shopify.com/"
  },
  {
    "name": "Global",
    "settings": [
      {
        "type": "header",
        "content": "Favicon"
      },
      {
        "type": "image_picker",
        "id": "favicon",
        "label": "Favicon",
        "info": "180 x 180px .png recommended"
      },
      {
        "type": "header",
        "content": "Colors"
      },
      {
        "type": "color_scheme_group",
        "id": "color_schemes",
        "definition": [
          {
            "type": "color",
            "id": "background",
            "label": "Background"
          },
          {
            "type": "color",
            "id": "foreground",
            "label": "Foreground"
          },
          {
            "type": "color",
            "id": "primary",
            "label": "Primary"
          },
          {
            "type": "color",
            "id": "primary_foreground",
            "label": "Primary foreground"
          },
          {
            "type": "color",
            "id": "secondary",
            "label": "Secondary"
          },
          {
            "type": "color",
            "id": "secondary_foreground",
            "label": "Secondary foreground"
          }
        ],
        "role": {
          "text": "foreground",
          "background": "background",
          "primary_button": "primary",
          "on_primary_button": "primary_foreground",
          "primary_button_border": "primary",
          "secondary_button": "secondary",
          "on_secondary_button": "secondary_foreground",
          "secondary_button_border": "secondary_foreground",
          "links": "primary",
          "icons": "foreground"
        }
      },
      {
        "type": "header",
        "content": "Typography"
      },
      {
        "type": "font_picker",
        "id": "font_primary",
        "label": "Primary Font",
        "default": "geist_n4"
      },
      {
        "type": "header",
        "content": "Sections"
      },
      {
        "type": "range",
        "id": "section_width",
        "label": "Section width",
        "min": 800,
        "max": 2000,
        "step": 100,
        "unit": "px",
        "default": 1200,
      },
      {
        "type": "range",
        "id": "section_vertical_padding",
        "label": "Vertical padding",
        "min": 0,
        "max": 4,
        "step": 1,
        "unit": "rem",
        "default": 3,
      },
      {
        "type": "range",
        "id": "section_horizontal_padding",
        "label": "Horizontal padding",
        "min": 0,
        "max": 4,
        "step": 1,
        "unit": "rem",
        "default": 1,
      },
      {
        "type": "header",
        "content": "Sidebar"
      },
      {
        "type": "range",
        "id": "sidebar_width",
        "label": "Width",
        "min": 150,
        "max": 400,
        "step": 10,
        "unit": "px",
        "default": 250
      }
    ]
  },
  {
    "name": "Cart",
    "settings": [
      {
        "type": "select",
        "id": "cart_behavior",
        "label": "Cart behavior",
        "options": [
          {
            "value": "drawer",
            "label": "Drawer"
          },
          {
            "value": "cart_page",
            "label": "Cart page"
          }
        ],
        "default": "drawer"
      },
      {
        "type": "richtext",
        "id": "cart_empty_content",
        "label": "Empty cart content",
        "default": "<h1>Cart</h1><p>Your cart is empty.</p>"
      },
      {
        "type": "url",
        "id": "cart_empty_link",
        "label": "Empty cart link"
      }
    ]
  }
]
