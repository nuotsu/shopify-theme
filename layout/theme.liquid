<!doctype html>
<html lang="{{ request.locale.iso_code }}">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width,initial-scale=1">

  {% render 'metadata' %}

  <link rel="canonical" href="{{ canonical_url }}">

  {%- if settings.favicon -%}
    <link rel="icon" href="{{ settings.favicon | image_url: width: 32 }}" sizes="32x32">
    <link rel="icon" href="{{ settings.favicon | image_url: width: 96 }}" sizes="96x96">
    <link rel="apple-touch-icon" href="{{ settings.favicon | image_url: width: 180 }}">
  {%- endif -%}

  {% render 'css-variables' %}
  {% render 'fonts' %}
  {{ 'tailwind.min.css' | asset_url | stylesheet_tag: preload: true }}

  <script src="{{ 'scripts.js' | asset_url }}" defer></script>

  {%- if request.page_type == 'product' -%}
    <script type="application/ld+json">
      {{ product | structured_data }}
    </script>

    <meta property="og:price:amount" content="{{ product.price | money_without_currency | strip_html }}">
    <meta property="og:price:currency" content="{{ cart.currency.iso_code }}">
  {%- endif -%}

  {{ content_for_header }}
</head>
<body>
  {% sections 'header-group' %}

  <main>
    {{ content_for_layout }}
  </main>

  {% sections 'footer-group' %}
</body>
</html>
