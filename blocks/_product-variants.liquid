{%- if closest.product.has_only_default_variant -%}
  <input
    type="hidden"
    name="id"
    value="{{ closest.product.selected_or_first_available_variant.id }}"
  >
{%- else -%}
  <div data-product-options>
    <label
      class="flex items-center gap-2"
      {% if block.settings.display == 'radio' %} hidden {% endif %}
    >
      <span>Options:</span>

      <select name="id" id="id-{{ block.id }}" class="ghost grow">
        {%- for variant in closest.product.variants -%}
          <option
            value="{{ variant.id }}"
            {% if variant.selected %} selected {% endif %}
            {% unless variant.available %} disabled {% endunless %}
          >
            {{- variant.title -}}
          </option>
        {%- endfor -%}
      </select>
    </label>

    {%- if block.settings.display == 'radio' -%}
      <div class="grid gap-4">
        {%- for option in closest.product.options_with_values -%}
          <fieldset>
            <legend>
              {{ option.name }}:
              <b class="anim-fade" data-option-value>{{ option.selected_value }}</b>
            </legend>

            <div class="flex flex-wrap items-center gap-[.25em] leading-tight">
              {%- for value in option.values -%}
                {%- liquid
                  assign swatch = nil
                  if block.settings.enable_color_swatches
                    assign swatch = closest.product.metafields.shopify.color-pattern.value | find: 'label', value
                  endif
                -%}

                <label class="
                  action-outline not-has-checked:border-current/25 has-disabled:opacity-25 has-disabled:bg-current/25
                  has-[.swatch]:size-[1.5lh] has-[.swatch]:rounded-full has-[.swatch]:p-[3px] has-[.swatch]:order-first
                  not-has-[.swatch]:min-w-[3ch]
                ">
                  <input
                    type="radio"
                    name="{{ option.name }}"
                    value="{{ value }}"
                    id="{{ option.name }}-{{ value }}-{{ block.id }}"
                    {% if value == option.selected_value %} checked {% endif %}
                    {% unless value.available %} disabled {% endunless %}
                    class="sr-only"
                  >

                  {%- if swatch -%}
                    <div
                      class="swatch inline-block size-full rounded-full"
                      style="background-color: {{ swatch.color }};"
                      title="{{ value }}"
                    ></div>

                  {%- else -%}
                    {{ value }}

                  {%- endif -%}
                </label>

                {%- if swatch -%}
                  <hr class="not-last-of-type:hidden order-first w-full border-none">
                {%- endif -%}
              {%- endfor -%}
            </div>
          </fieldset>
        {%- endfor -%}
      </div>

      <script type="application/json" data-variants>
        {{ closest.product.variants | json }}
      </script>

      <script>
        (() => {
          const container = document.currentScript.closest('[data-product-options]')
          if (!container) return

          const select = container.querySelector('select[name="id"]')
          const variantsEl = container.querySelector('[data-variants]')
          if (!select || !variantsEl) return

          let variants
          try {
            variants = JSON.parse(variantsEl.textContent)
          } catch {
            return
          }

          const fieldsets = [...container.querySelectorAll('fieldset')]

          const getSelected = () =>
            fieldsets.map(
              (fieldset) => fieldset.querySelector('input[type="radio"]:checked')?.value
            )

          const isAvailable = (optionIndex, value, selected) =>
            variants.some(
              (v) =>
                v.available &&
                v.options[optionIndex] === value &&
                v.options.every((opt, i) => i >= optionIndex || opt === selected[i])
            )

          const syncSelectFromRadios = () => {
            const selected = getSelected()
            if (selected.some((value) => value == null)) return

            const variant = variants.find(
              (v) =>
                v.available && v.options.every((opt, i) => opt === selected[i])
            )

            if (!variant) return

            select.value = String(variant.id)
            select.dispatchEvent(new Event('change', { bubbles: true }))
          }

          const updateOptionValueLabels = () => {
            fieldsets.forEach((fieldset) => {
              const label = fieldset.querySelector('[data-option-value]')
              const value = fieldset.querySelector('input[type="radio"]:checked')?.value
              if (!label || value == null || label.textContent === value) return

              const next = label.cloneNode(false)
              next.textContent = value
              label.replaceWith(next)
            })
          }

          const updateDisabledRadios = () => {
            let selected = getSelected()

            const applyDisabled = () => {
              fieldsets.forEach((fieldset, optionIndex) => {
                fieldset.querySelectorAll('input[type="radio"]').forEach((input) => {
                  input.disabled = !isAvailable(optionIndex, input.value, selected)
                })
              })
            }

            applyDisabled()

            let didFallback = false
            fieldsets.forEach((fieldset, optionIndex) => {
              const checked = fieldset.querySelector('input[type="radio"]:checked')
              if (!checked?.disabled) return

              const fallback = fieldset.querySelector('input[type="radio"]:not(:disabled)')
              if (!fallback) return

              fallback.checked = true
              selected[optionIndex] = fallback.value
              didFallback = true
            })

            if (didFallback) applyDisabled()

            updateOptionValueLabels()
            syncSelectFromRadios()
          }

          container.addEventListener('change', (event) => {
            if (event.target.matches('input[type="radio"]')) {
              updateDisabledRadios()
            }
          })

          updateDisabledRadios()
        })()
      </script>
    {%- endif -%}
  </div>
{%- endif -%}

{% schema %}
{
  "name": "Variants",
  "settings": [
    {
      "type": "select",
      "id": "display",
      "label": "Display",
      "options": [
        {
          "value": "radio",
          "label": "Radio"
        },
        {
          "value": "dropdown",
          "label": "Dropdown"
        }
      ],
      "default": "radio"
    },
    {
      "type": "checkbox",
      "id": "enable_color_swatches",
      "label": "Enable color swatches",
      "default": true,
      "info": "Uses metafields (\"shopify.color-pattern\")",
      "visible_if": "{{ block.settings.display == 'radio' }}"
    },
  ],
  "presets": [
    {
      "name": "Variants",
      "category": "Product"
    }
  ]
}
{% endschema %}
