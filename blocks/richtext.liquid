<div class="prose {% if block.settings.enable_h0 %} [&_h1,h2]:h0 {% endif %}">
  {{ block.settings.content }}
</div>

{% if block.settings.font_size != '' %}
  <style>
    @scope {
      .prose {
        font-size: {{ block.settings.font_size }};
        text-align: {{ block.settings.text_align }};
      }
    }
  </style>
{% endif %}

{% schema %}
{
  "name": "Richtext",
  "settings": [
    {
      "type": "richtext",
      "id": "content",
      "label": "Content",
      "default": "<h2>Heading 2</h2><p>Lorem ipsum dolor, sit amet consectetur adipisicing elit.</p>"
    },
    {
      "type": "select",
      "id": "text_align",
      "label": "Text align",
      "options": [
        {
          "value": "inherit",
          "label": "Inherit"
        },
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "inherit"
    },
    {
      "type": "select",
      "id": "font_size",
      "label": "Font size",
      "options": [
        {
          "value": "smaller",
          "label": "Smaller"
        },
        {
          "value": "",
          "label": "Default"
        },
        {
          "value": "larger",
          "label": "Larger"
        }
      ],
      "default": "",
    },
    {
      "type": "checkbox",
      "id": "enable_h0",
      "label": "Large heading",
      "default": false,
      "info": "Applied to H1 and H2 only"
    },
  ],
  "presets": [
    {
      "name": "Richtext"
    },
    {
      "name": "Description",
      "settings": {
        "content": "{{ closest.product.description }}"
      },
      "category": "Product"
    }
  ]
}
{% endschema %}
