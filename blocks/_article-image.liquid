{%- assign item = closest.article | default: article -%}

{%- if item.image -%}
  <figure class="group-hover/card:brightness-110 transition-[filter]">
    {{ item.image
      | image_url: width: 1600
      | image_tag: class: 'w-full object-cover', loading: 'eager', draggable: 'false'
    }}
  </figure>
{%- endif -%}

<style>
  @scope {
    img {
      aspect-ratio: {{ block.settings.aspect_ratio }};
    }
  }
</style>

{% schema %}
{
  "name": "Image",
  "class": "article-image",
  "settings": [
    {
      "type": "select",
      "id": "aspect_ratio",
      "label": "Aspect ratio",
      "options": [
        {
          "value": "none",
          "label": "Original"
        },
        {
          "value": "4 / 3",
          "label": "Landscape"
        },
        {
          "value": "1 / 1",
          "label": "Square"
        },
      ],
      "default": "none"
    },
  ],
  "presets": [
    {
      "name": "Image",
      "category": "Article"
    }
  ]
}
{% endschema %}
