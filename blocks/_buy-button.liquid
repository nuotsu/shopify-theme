{%- liquid
  assign variant = closest.product.selected_or_first_available_variant
  assign sold_out = false
  if variant.available == false
    assign sold_out = true
  endif
-%}

<button
  type="submit"
  class="{{ block.settings.style }} w-full disabled:opacity-25"
  data-buy-button
  data-cart-behavior="{{ settings.cart_behavior }}"
  data-cart-url="{{ routes.cart_url }}"
  data-add-to-cart-label="Add to cart"
  data-sold-out-label="Sold out"
  {% if sold_out %} disabled {% endif %}
>
  {%- if sold_out -%} Sold out {%- else -%} Add to cart {%- endif -%}
</button>

{% javascript %}
  const root = window.Shopify?.routes?.root || '/'
  const addUrl = `${root}cart/add.js`
  const cartUrl = `${root}cart.js`

  const updateCartCount = (itemCount) => {
    document.querySelectorAll('[data-cart-count]').forEach((el) => {
      el.textContent = `(${itemCount})`
      el.classList.toggle('hidden', itemCount <= 0)
    })
  }

  const refreshCartLines = async (cartDrawer) => {
    const lines = cartDrawer?.querySelector('[data-cart-lines]')
    const sectionId = lines?.dataset.sectionId || cartDrawer?.dataset.sectionId
    if (!sectionId || !lines) return

    lines.querySelectorAll('[data-cart-loading]').forEach((el) => {
      el.toggleAttribute('data-loading', true)
    })

    try {
      const fetchUrl = new URL(window.location.href)
      fetchUrl.searchParams.set('section_id', sectionId)

      const response = await fetch(fetchUrl.toString())
      if (!response.ok) throw new Error(`Section fetch failed: ${response.status}`)

      const html = await response.text()
      const doc = new DOMParser().parseFromString(html, 'text/html')
      const newLines = doc.querySelector('[data-cart-lines]')
      if (!newLines) return

      lines.innerHTML = newLines.innerHTML
      document.dispatchEvent(new CustomEvent('cart:updated'))
    } catch {
      lines.querySelectorAll('[data-cart-loading]').forEach((el) => {
        el.toggleAttribute('data-loading', false)
      })
      // Drawer can still open with stale lines; count is already updated.
    }
  }

  const updateAvailability = (button, selectedOption) => {
    const soldOut = selectedOption?.disabled === true
    button.disabled = soldOut
    button.textContent = soldOut ? button.dataset.soldOutLabel : button.dataset.addToCartLabel
  }

  const bindVariantAvailability = (button, form) => {
    const select = form.querySelector('select[name="id"]')
    if (!select) return

    updateAvailability(button, select.selectedOptions[0])
    select.addEventListener('change', () => {
      updateAvailability(button, select.selectedOptions[0])
    })
  }

  const bindBuyButton = (button) => {
    if (button.dataset.buyButtonBound === 'true') return
    button.dataset.buyButtonBound = 'true'

    const form = button.closest('form')
    if (!form) return

    bindVariantAvailability(button, form)

    form.addEventListener('submit', async (event) => {
      if (button.dataset.cartBehavior !== 'drawer') return

      event.preventDefault()

      const cartDrawer = document.getElementById('cart-drawer')
      const fallbackCartUrl = button.dataset.cartUrl || `${root}cart`

      try {
        const addResponse = await fetch(addUrl, {
          method: 'POST',
          headers: { Accept: 'application/json' },
          body: new FormData(form),
        })

        if (!addResponse.ok) throw new Error(`Add failed: ${addResponse.status}`)

        const cartResponse = await fetch(cartUrl, {
          headers: { Accept: 'application/json' },
        })
        if (!cartResponse.ok) throw new Error(`Cart fetch failed: ${cartResponse.status}`)

        const cart = await cartResponse.json()
        updateCartCount(cart.item_count ?? 0)

        if (cartDrawer?.showModal) {
          await refreshCartLines(cartDrawer)
          cartDrawer.showModal()
        } else {
          window.location.href = fallbackCartUrl
        }
      } catch {
        window.location.href = fallbackCartUrl
      }
    })
  }

  document.querySelectorAll('[data-buy-button]').forEach(bindBuyButton)
{% endjavascript %}

{% schema %}
{
  "name": "Buy button",
  "settings": [
    {
      "type": "select",
      "id": "style",
      "label": "Style",
      "options": [
        {
          "value": "action",
          "label": "Action"
        },
        {
          "value": "action-outline",
          "label": "Outline"
        },
        {
          "value": "ghost",
          "label": "Ghost"
        }
      ],
      "default": "action"
    }
  ],
  "presets": [
    {
      "name": "Buy button",
      "category": "Product"
    }
  ]
}
{% endschema %}
