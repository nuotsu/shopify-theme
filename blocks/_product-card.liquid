<li class="relative flex flex-col gap-4 leading-tight">
  {% content_for 'blocks', closest.product: closest.product %}
</li>

{% schema %}
{
  "name": "Product card",
  "settings": [],
  "blocks": [
    { "type": "_product-card-image" },
    { "type": "_product-card-title" },
    { "type": "_product-card-price" },
    { "type": "_product-card-variants" },
    { "type": "@app" }
  ],
  "presets": [
    {
      "name": "Product card",
      "blocks": {
        "product-card-image": {
          "type": "_product-card-image",
          "name": "Image"
        },
        "product-card-title": {
          "type": "_product-card-title",
          "name": "Title"
        },
        "product-card-price": {
          "type": "_product-card-price",
          "name": "Price"
        },
        "product-card-variants_color": {
          "type": "_product-card-variants",
          "name": "Swatches"
        },
        "product-card-variants_size": {
          "type": "_product-card-variants",
          "name": "Swatches",
          "settings": {
            "option_name": "Size"
          }
        },
      },
      "block_order": [
        "product-card-image",
        "product-card-title",
        "product-card-price",
        "product-card-variants_color",
        "product-card-variants_size"
      ]
    }
  ]
}
{% endschema %}
