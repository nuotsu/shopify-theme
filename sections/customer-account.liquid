<div class="section grid gap-lh">
  <div class="prose">
    <h1>My account</h1>
    <p>Welcome, {{ customer.name | default: customer.email }}.</p>
  </div>

  <div class="flex flex-wrap gap-4">
    <a class="action" href="{{ routes.account_addresses_url }}">Addresses</a>
    <a class="action-outline" href="{{ routes.account_logout_url }}">Logout</a>
  </div>

  {% paginate customer.orders by 20 %}
    {% if customer.orders.size > 0 %}
      <table class="w-full text-left">
        <thead>
          <tr>
            <th>Order</th>
            <th>Date</th>
            <th>Payment status</th>
            <th>Fulfillment status</th>
            <th>Total</th>
          </tr>
        </thead>
        <tbody>
          {% for order in customer.orders %}
            <tr>
              <td><a href="{{ order.customer_url }}">{{ order.name }}</a></td>
              <td>{{ order.created_at | date: '%B %d, %Y' }}</td>
              <td>{{ order.financial_status_label }}</td>
              <td>{{ order.fulfillment_status_label }}</td>
              <td>{{ order.total_price | money }}</td>
            </tr>
          {% endfor %}
        </tbody>
      </table>

      {{- paginate | default_pagination -}}
    {% else %}
      <p>You haven't placed any orders yet.</p>
    {% endif %}
  {% endpaginate %}
</div>

{% schema %}
{
  "name": "Customer account"
}
{% endschema %}
