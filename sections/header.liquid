<div class="header-layout grid items-center gap-x-4">
  <a href="{{ routes.root_url }}" class="[grid-area:logo]">
    {{ shop.name }}
  </a>

  <nav class="[grid-area:menu] md:flex items-center gap-x-4 max-md:menu-not-open:hidden">
    {% for link in section.settings.menu.links %}
      {%- case link.levels -%}
        {%- when 2 -%} {% # megamenu %}
          <details class="accordion" name="header-{{ section.id }}" data-hover-details>
            <summary>
              {{ link.title }}
              {{ 'icon-chevron-down.svg' | inline_asset_content }}
            </summary>
            <div class="anim-fade-to-b md:absolute top-full inset-x-0 md:bg-background md:shadow-lg columns-[24ch] gap-x-4">
              {% for lv1_link in link.links %}
                <details class="break-inside-avoid" data-mobile-only-details>
                  <summary>{{ lv1_link.title }}</summary>
                  <ul>
                    {% for lv2_link in lv1_link.links %}
                      <li><a href="{{ lv2_link.url }}">{{ lv2_link.title }}</a></li>
                    {% endfor %}
                  </ul>
                </details>
              {% endfor %}
            </div>
          </details>

        {%- when 1 -%} {% # dropdown %}
          <details class="accordion relative" name="header-{{ section.id }}" data-hover-details>
            <summary>
              {{ link.title }}
              {{ 'icon-chevron-down.svg' | inline_asset_content }}
            </summary>
            <ul class="anim-fade-to-b md:absolute top-full left-0 md:min-w-max md:bg-background md:shadow-lg">
              {% for lv1_link in link.links %}
                <li><a href="{{ lv1_link.url }}">{{ lv1_link.title }}</a></li>
              {% endfor %}
            </ul>
          </details>

        {%- else -%} {% # top-level link %}
          <a href="{{ link.url }}">{{ link.title }}</a>
      {%- endcase -%}
    {% endfor %}
  </nav>

  <nav class="[grid-area:actions] flex items-center gap-x-4">
    <details class="accordion relative" name="header-{{ section.id }}" data-hover-details>
      <summary>
        Account
        {{ 'icon-chevron-down.svg' | inline_asset_content }}
      </summary>
      <ul class="anim-fade-to-b md:absolute top-full left-0 md:min-w-max md:bg-background md:shadow-lg">
        {% if customer %}
          <li><a href="{{ routes.account_url }}">My Account</a></li>
          <li><a href="{{ routes.account_logout_url }}">Logout</a></li>
        {% else %}
          <li><a href="{{ routes.account_login_url }}">Login</a></li>
          <li><a href="{{ routes.account_register_url }}">Register</a></li>
        {% endif %}
      </ul>
    </details>

    {% if settings.enable_cart_drawer %}
      {% render 'cart-drawer' %}
    {% else %}
      <a href="{{ routes.cart_url }}">
        Cart
        <span class="{% unless cart.item_count > 0 %} hidden {% endunless %}">({{ cart.item_count }})</span>
      </a>
    {% endif %}
  </nav>

  <label class="[grid-area:toggle] group/toggle md:hidden" aria-label="Toggle menu">
    <input id="menu-open" type="checkbox" hidden />
    <span class="menu-open:hidden">{{ 'icon-menu.svg' | inline_asset_content }}</span>
    <span class="menu-not-open:hidden">{{ 'icon-close.svg' | inline_asset_content }}</span>
  </label>
</div>

<style>
  @scope {
    :scope {
      .header-layout {
        grid-template: 'logo menu actions' / auto 1fr auto;

        @media (width < 48rem) {
          grid-template:
            'logo actions toggle' auto
            'menu menu menu' auto / 1fr auto auto;
        }
      }
    }
  }
</style>

{% schema %}
{
  "name": "Header",
  "tag": "header",
  "class": "sticky top-0 border-b",
  "settings": [
    {
      "type": "link_list",
      "id": "menu",
      "label": "Menu",
      "default": "main-menu",
      "info": "1 level of nesting = dropdown; 2 levels = megamenu."
    }
  ]
}
{% endschema %}
