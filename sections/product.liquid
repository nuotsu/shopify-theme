{%- assign layout = section.settings.layout -%}

<div class="
  [--offset:1rem]
  {% if layout == 'vertical' %} md:section grid md:grid-cols-[1fr_min(50%,var(--column-width))] gap-x-[2lh] items-start *:md:sticky-below-header {% endif %}
">
  {% render 'product-gallery', product: product, section: section %}

  <article class="
    grid gap-y-4
    {% if layout == 'horizontal' %} section md:grid-cols-[1fr_min(50%,var(--column-width))] gap-x-[2lh] items-start
    {% else %} max-md:section
    {% endif %}
  ">
    <div class="{% if layout == 'horizontal' %} md:sticky-below-header grid gap-4 max-md:contents {% else %} contents {% endif %}">
      {%- content_for 'block', type: '_product-top', id: 'product-top' -%}

      <div class="
        not-has-[.product-bottom>*]:hidden
        {% if layout == 'horizontal' %} max-md:order-last {% else %} order-last {% endif %}
      ">
        {%- content_for 'block', type: '_product-bottom', id: 'product-bottom' -%}
      </div>
    </div>

    <div class="{% if layout == 'horizontal' %} md:sticky-below-header {% else %} contents {% endif %}">
      {%- content_for 'block', type: '_product-form', id: 'product-form' -%}
    </div>
  </article>
</div>

<style>
  @scope {
    :scope {
      --column-width: {{ section.settings.column_width }}px;
      --gallery-height: {{ section.settings.gallery_height }}px;
      --gallery-gap: {{ section.settings.gallery_gap }}px;
    }
  }
</style>

{% schema %}
{
  "name": "Product",
  "tag": "section",
  "settings": [
    {
      "type": "select",
      "id": "layout",
      "label": "Layout",
      "options": [
        {
          "value": "horizontal",
          "label": "Horizontal"
        },
        {
          "value": "vertical",
          "label": "Vertical"
        }
      ],
      "default": "horizontal"
    },
    {
      "type": "range",
      "id": "column_width",
      "label": "Column width",
      "min": 200,
      "max": 800,
      "step": 50,
      "unit": "px",
      "default": 400
    },
    {
      "type": "header",
      "content": "Gallery"
    },
    {
      "type": "checkbox",
      "id": "enable_carousel",
      "label": "Enable carousel",
      "default": false,
      "info": "Desktop only",
      "visible_if": "{{ section.settings.layout == 'vertical' }}"
    },
    {
      "type": "checkbox",
      "id": "enable_two_column",
      "label": "Enable two-column",
      "default": true,
      "info": "Desktop only",
      "visible_if": "{{ section.settings.layout == 'vertical' and section.settings.enable_carousel == false }}"
    },
    {
      "type": "range",
      "id": "gallery_height",
      "label": "Height",
      "min": 200,
      "max": 800,
      "step": 50,
      "unit": "px",
      "default": 400
    },
    {
      "type": "range",
      "id": "gallery_gap",
      "label": "Gap",
      "min": 0,
      "max": 20,
      "step": 1,
      "unit": "px",
      "default": 1
    },
    {
      "type": "checkbox",
      "id": "filter_gallery_by_selection",
      "label": "Filter gallery by selection",
      "info": "Shows images whose alt text includes the selected option (for example Color: Red).",
      "default": true
    },
    {
      "type": "textarea",
      "id": "options_to_match",
      "label": "Options to match",
      "default": "Color",
      "placeholder": "Color",
      "info": "List product options to use (one per line). Images with that option’s value in their alt text are shown.",
      "visible_if": "{{ section.settings.filter_gallery_by_selection == true }}"
    },
  ],
  "blocks": [
    { "type": "_product-top" },
    { "type": "_product-form" },
    { "type": "_product-bottom" },
  ]
}
{% endschema %}
