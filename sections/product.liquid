{%- liquid
  assign layout = section.settings.layout
-%}

<div class="
  [--offset:1rem]
  {% if layout == 'vertical' %} md:section grid md:grid-cols-[1fr_min(50%,var(--column-width))] gap-x-[2lh] items-start *:md:sticky-below-header {% endif %}
">
  <figure
    class="
      flex gap-(--gallery-gap) items-center snap-x snap-mandatory *:snap-center *:shrink-0 overflow-x-auto
      {% if layout == 'horizontal' %}
        carousel-scroll-buttons carousel-scroll-marker *:md:h-(--gallery-height)
        {% if product.media.size > 1 %} *:max-w-[calc(100vw-2rem)] {% endif %}
      {% else %} {% # vertical %}
        {% if product.media.size > 1 %} max-md:*:max-w-[calc(100vw-2rem)] {% endif %}
        {% if section.settings.enable_carousel %} carousel-scroll-buttons carousel-scroll-marker md:*:aspect-square
        {% else %}
          md:flex-col max-md:carousel-scroll-buttons max-md:carousel-scroll-marker
          {% if section.settings.enable_two_column and product.media.size > 1 %} md:grid md:grid-cols-2 {% endif %}
        {% endif %}
      {% endif %}
    "
  >
    {%- for media in product.media -%}
      {%- liquid
        if forloop.first
          assign loading = 'eager'
        else
          assign loading = 'lazy'
        endif
      -%}

      {%- case media.media_type -%}
        {%- when 'image' -%}
          {{ media | image_url: width: 800 | image_tag: class: 'w-auto object-contain', loading: loading, draggable: false }}

        {%- when 'video' -%}
          {%- assign poster = media.preview_image | image_url: width: 800 -%}
          {{ media | video_tag: class: 'w-auto object-contain', poster: poster, controls: 'true', loading: loading }}

        {%- when 'model' -%}
          {{ media | model_viewer_tag: class: 'w-auto object-contain', loading: loading, draggable: false }}

        {%- endcase -%}
    {%- endfor -%}
  </figure>

  <article class="
    grid gap-y-4
    {% if layout == 'horizontal' %} section md:grid-cols-[1fr_min(50%,var(--column-width))] gap-x-[2lh] items-start
    {% else %} max-md:section
    {% endif %}
  ">
    <div class="{% if layout == 'horizontal' %} md:sticky-below-header grid gap-4 max-md:contents {% else %} contents {% endif %}">
      {%- content_for 'block', type: '_product-top', id: 'product-top' -%}

      <div class="
        not-has-[.product-bottom>*]:hidden
        {% if layout == 'horizontal' %} max-md:order-last {% else %} order-last {% endif %}
      ">
        {%- content_for 'block', type: '_product-bottom', id: 'product-bottom' -%}
      </div>
    </div>

    <div class="{% if layout == 'horizontal' %} md:sticky-below-header {% else %} contents {% endif %}">
      {%- content_for 'block', type: '_product-form', id: 'product-form' -%}
    </div>
  </article>
</div>

<style>
  @scope {
    :scope {
      --column-width: {{ section.settings.column_width }}px;
      --gallery-height: {{ section.settings.gallery_height }}px;
      --gallery-gap: {{ section.settings.gallery_gap }}px;
    }
  }
</style>

{% schema %}
{
  "name": "Product",
  "tag": "section",
  "settings": [
    {
      "type": "select",
      "id": "layout",
      "label": "Layout",
      "options": [
        {
          "value": "horizontal",
          "label": "Horizontal"
        },
        {
          "value": "vertical",
          "label": "Vertical"
        }
      ],
      "default": "horizontal"
    },
    {
      "type": "range",
      "id": "column_width",
      "label": "Column width",
      "min": 200,
      "max": 800,
      "step": 50,
      "unit": "px",
      "default": 400
    },
    {
      "type": "header",
      "content": "Gallery"
    },
    {
      "type": "checkbox",
      "id": "enable_carousel",
      "label": "Enable carousel",
      "default": false,
      "info": "Desktop only",
      "visible_if": "{{ section.settings.layout == 'vertical' }}"
    },
    {
      "type": "checkbox",
      "id": "enable_two_column",
      "label": "Enable two-column",
      "default": false,
      "info": "Desktop only",
      "visible_if": "{{ section.settings.layout == 'vertical' and section.settings.enable_carousel == false }}"
    },
    {
      "type": "range",
      "id": "gallery_height",
      "label": "Height",
      "min": 200,
      "max": 800,
      "step": 50,
      "unit": "px",
      "default": 400
    },
    {
      "type": "range",
      "id": "gallery_gap",
      "label": "Gap",
      "min": 0,
      "max": 20,
      "step": 1,
      "unit": "px",
      "default": 1
    }
  ],
  "blocks": [
    { "type": "_product-top" },
    { "type": "_product-form" },
    { "type": "_product-bottom" },
  ]
}
{% endschema %}
