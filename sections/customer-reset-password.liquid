<div class="section grid gap-lh justify-center text-center">
  <div class="prose">
    <h1>Reset password</h1>
  </div>

  {% form 'reset_customer_password', class: 'grid gap-2 max-w-[24rem] mx-auto text-left' %}
    {{ form.errors | default_errors }}

    <label>
      <span class="sr-only">New password</span>
      <input
        class="w-full p-[.25em_.5em] border"
        type="password"
        name="customer[password]"
        autocomplete="new-password"
        placeholder="New password"
        required
      >
    </label>

    <label>
      <span class="sr-only">Confirm new password</span>
      <input
        class="w-full p-[.25em_.5em] border"
        type="password"
        name="customer[password_confirmation]"
        autocomplete="new-password"
        placeholder="Confirm new password"
        required
      >
    </label>

    <button class="action w-full" type="submit">
      Reset password
    </button>
  {% endform %}
</div>

{% schema %}
{
  "name": "Customer reset password"
}
{% endschema %}
