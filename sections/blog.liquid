{%- liquid
  if section.settings.feature_type == 'newest'
    assign featured_articles = blog.articles | slice: 0, 1
  elsif section.settings.feature_type == 'curated'
    assign featured_articles = section.settings.featured_list
  endif
-%}

<div class="section grid md:grid-cols-[auto_1fr] items-start gap-[2lh]">
  <aside class="md:sticky-below-header [--offset:1rem] md:w-(--sidebar-width) flex flex-col gap-lh">
    <header class="prose">
      {{ section.settings.content }}
    </header>

    {% render 'search-form', type: 'article' %}

    {%- if blog.tags.size > 0 -%}
      <div class="grid text-sm grow overflow-y-auto mask-b-from-[calc(100%-2rem)] max-md:max-h-[7.5lh]">
        <div class="sticky top-0 z-1 pb-2 bg-background">Tags</div>

        <ul class="flex flex-wrap gap-1 pb-lh">
          {%- for tag in blog.tags -%}
            <li>
              <a
                href="{{ blog.url }}/tagged/{{ tag | handle }}"
                class="
                  inline-block p-[.125em_.25em] bg-current/5 before:content-['#'] before:text-current/50 hover:underline
                  {% if current_tags contains tag %} font-bold {% endif %}
                "
              >
                {{- tag -}}
              </a>
            </li>
          {%- endfor -%}

          {%- if current_tags -%}
            <li class="w-full">
              <a href="{{ blog.url }}" class="block p-[.25em] hover:underline text-current/50">
                Clear tags
              </a>
            </li>
          {%- endif -%}
        </ul>
      </div>
    {%- endif -%}

    <div class="prose text-center border-t pt-lh {% if featured_articles != blank %} max-md:hidden {% endif %}">
      {{ section.settings.subscribe_content }}

      {% render 'contact-form' %}
    </div>
  </aside>

  <div class="@container/blog grid gap-lh">
    {%- if featured_articles != blank -%}
      <div class="grid gap-lh border-b pb-lh">
        {%- liquid
          for article in featured_articles
            content_for 'block', type: '_featured-article', id: 'featured-article', closest.article: article
          endfor
        -%}
      </div>

      <div class="prose text-center md:hidden">
        {{ section.settings.subscribe_content }}

        {% render 'contact-form' %}
      </div>
    {%- endif -%}


    {%- paginate blog.articles by section.settings.articles_per_page -%}
      <ul class="article-list grid grid-cols-[repeat(auto-fill,minmax(min(var(--column-width),100%),1fr))] items-start gap-x-(--gap) gap-y-lh">
        {%- liquid
          for article in blog.articles limit: section.settings.limit
            content_for 'block', type: '_article-card', id: 'article-card', closest.article: article
          endfor
        -%}
      </ul>

      {%- if paginate.pages > 1 -%}
        <div class="pagination">
          {{- paginate | default_pagination -}}
        </div>
      {%- endif -%}
    {% endpaginate %}
  </div>
</div>

<style>
  @scope {
    .article-list {
      --column-width: {{ section.settings.column_width }}px;
      --gap: {{ section.settings.gap }}px;

      li > :not(.article-image) {
        padding-inline: max(0px, calc(.5rem - var(--gap)));
      }
    }

    aside {
      @media (width >= 48rem) {
        max-height: calc(100svh - var(--header-height) - max(2rem, 1rem + env(safe-area-inset-bottom)));
      }
    }
  }
</style>

{% schema %}
{
  "name": "Blog",
  "tag": "section",
  "settings": [
    {
      "type": "richtext",
      "id": "content",
      "label": "Content",
      "default": "<h1>{{ blog.title }}</h1>"
    },
    {
      "type": "header",
      "content": "Featured"
    },
    {
      "type": "select",
      "id": "feature_type",
      "label": "Feature type",
      "options": [
        {
          "value": "newest",
          "label": "Newest"
        },
        {
          "value": "curated",
          "label": "Curated"
        }
      ],
      "default": "newest"
    },
    {
      "type": "article_list",
      "id": "featured_list",
      "label": "Articles",
      "info": "If featured type is curated",
      "limit": 3
    },
    {
      "type": "header",
      "content": "Articles"
    },
    {
      "type": "range",
      "id": "column_width",
      "label": "Column width",
      "min": 100,
      "max": 600,
      "step": 50,
      "unit": "px",
      "default": 250
    },
    {
      "type": "range",
      "id": "gap",
      "label": "Gap",
      "min": 0,
      "max": 30,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "limit",
      "label": "Limit",
      "min": 1,
      "max": 30,
      "step": 1,
      "default": 12
    },
    {
      "type": "header",
      "content": "Subscribe",
    },
    {
      "type": "richtext",
      "id": "subscribe_content",
      "label": "Content",
      "default": "<p>Subscribe to our newsletter to get the latest news and updates.</p>"
    }
  ],
  "blocks": [
    { "type": "_featured-article" },
    { "type": "_article-card" },
  ]
}
{% endschema %}
