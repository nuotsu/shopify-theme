{% style %}
  {{ settings.font_primary | font_face: font_display: 'swap' }}
  {{ settings.font_primary | font_modify: 'weight', 'bold' | font_face: font_display: 'swap' }}
  {{ settings.font_primary | font_modify: 'weight', 'bold' | font_modify: 'style', 'italic' | font_face: font_display: 'swap' }}
  {{ settings.font_primary | font_modify: 'style', 'italic' | font_face: font_display: 'swap' }}

  :root {
    --font-primary: {{ settings.font_primary.family }}, {{ settings.font_primary.fallback_families }};

    --color-background: {{ settings.color_schemes.scheme-1.settings.background }};
    --color-foreground: {{ settings.color_schemes.scheme-1.settings.foreground }};
    --color-primary: {{ settings.color_schemes.scheme-1.settings.primary }};
    --color-primary-foreground: {{ settings.color_schemes.scheme-1.settings.primary_foreground }};
    --color-secondary: {{ settings.color_schemes.scheme-1.settings.secondary }};
    --color-secondary-foreground: {{ settings.color_schemes.scheme-1.settings.secondary_foreground }};

    --section-width: {{ settings.section_width }}px;
    --section-vertical-padding: {{ settings.section_vertical_padding }}rem;
    --section-horizontal-padding: {{ settings.section_horizontal_padding }}rem;

    --sidebar-width: {{ settings.sidebar_width }}px;
  }
{% endstyle %}
